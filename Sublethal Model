## treatmeant R

```{r}
Euler <- function(r, lx, mx, time){
  sum(lx * mx * exp(-r * time)) - 1
}

calc_r <- function(df){
  uniroot(
    function(r) Euler(r, df$lx, df$mx, df$age_day),
    interval = c(-1, 1)
  )$root
}

r_results <- life_table_summary %>%
  group_by(Treatment) %>%
  group_modify(~ data.frame(r = calc_r(.x)))

r_results
```

