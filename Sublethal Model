```{r}
# Build offspring columns

nauplii_cols <- c("Nauplii..1.", 
                  "Nauplii..2.", 
                  "Nauplii..3.", 
                  "Nauplii..4.", 
                  "Nauplii..5.")

data[nauplii_cols] <- lapply(data[nauplii_cols], as.numeric)

data$cum_offspring <- rowSums(data[nauplii_cols], na.rm = TRUE)

data <- data[order(data$Individual.ID, data$Date), ]

data$all_egg <- ave(
  data$cum_offspring,
  data$Individual.ID,
  FUN = function(x) c(x[1], diff(x))
)

data$all_egg[is.na(data$all_egg)] <- 0
data$all_egg[data$all_egg < 0] <- 0

data$Treatment <- data$Treatment_phase1

```



```{r}

# Create clean life table dataset using TRUE biological age

data$days_since_treatment <- as.numeric(data$Date - data$Date.Started)

# organisms were already 12 days old when treatment began
data$true_age_day <- data$days_since_treatment + 12

life_table_data <- data.frame(
  age_day = data$true_age_day,
  exposure_day = data$days_since_treatment,
  ID = data$Individual.ID,
  reproduction = data$all_egg,
  Alive = data$Alive,
  Treatment = data$Treatment,
  Date.Started = data$Date.Started,
  Death.Date = data$Death.Date..if.before.21.days.
)

life_table_data <- life_table_data %>%
  filter(!is.na(age_day))

```



```{r}
# Expand data to include all TRUE biological ages

min_age <- 12
max_age <- max(life_table_data$age_day, na.rm = TRUE)

life_table_full <- life_table_data %>%
  group_by(ID, Treatment) %>%
  complete(age_day = min_age:max_age) %>%
  fill(Date.Started, Death.Date, .direction = "downup") %>%
  mutate(
    exposure_day = age_day - 12,
    current_date = Date.Started + exposure_day,
    reproduction = ifelse(is.na(reproduction), 0, reproduction),
    Alive = ifelse(
      !is.na(Death.Date) & current_date >= Death.Date,
      0,
      1
    )
  ) %>%
  ungroup()
```

```{r}
# Build life table summary

life_table_summary <- life_table_full %>%
  group_by(Treatment, age_day) %>%
  summarise(
    K0 = n_distinct(ID),
    Kx = sum(Alive == 1, na.rm = TRUE),
    births = sum(reproduction, na.rm = TRUE),
    mx = ifelse(Kx > 0, births / Kx, NA),
    .groups = "drop"
  ) %>%
  group_by(Treatment) %>%
  arrange(age_day, .by_group = TRUE) %>%
  mutate(
    lx = Kx / K0,
    dx = Kx - lead(Kx),
    qx = ifelse(Kx > 0, dx / Kx, NA),
    px = 1 - qx
  ) %>%
  ungroup()
```



