## Intrinsic growht rate by treatment 

```{r}
calc_r_individual <- function(df){
  Euler <- function(r, lx, mx, time){
    sum(lx * mx * exp(-r * time)) - 1
  }

  # build lx and mx for ONE individual
  lx <- df$Alive
  mx <- df$reproduction
  time <- df$age_day

  # avoid all-zero reproduction cases
  if(sum(mx) == 0) return(NA)

  tryCatch({
    uniroot(
      function(r) Euler(r, lx, mx, time),
      interval = c(-1, 1)
    )$root
  }, error = function(e) NA)
}

r_individual <- life_table_full %>%
  group_by(Treatment, ID) %>%
  group_modify(~ data.frame(r = calc_r_individual(.x))) %>%
  ungroup()

r_summary <- r_individual %>%
  group_by(Treatment) %>%
  summarise(
    mean_r = mean(r, na.rm = TRUE),
    sd_r = sd(r, na.rm = TRUE),
    se_r = sd_r / sqrt(n()),
    .groups = "drop"
  )

ggplot(r_summary, aes(x = Treatment, y = mean_r)) +
  geom_point(size = 3) +
  geom_errorbar(aes(ymin = mean_r - se_r, ymax = mean_r + se_r), width = 0.2) +
  labs(
    title = "Intrinsic Growth Rate (r) by Treatment",
    x = "Treatment",
    y = "r"
  )
```

